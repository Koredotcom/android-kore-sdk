<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/voice_background"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/voice_activity_title"
        android:textColor="@color/voice_text_white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Status Container -->
    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_status_container"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeader">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_status_indicator_inactive" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_status_ready"
            android:textColor="@color/voice_text_white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Avatar Section -->
    <LinearLayout
        android:id="@+id/avatarContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/controlsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusContainer">

        <FrameLayout
            android:id="@+id/avatarFrame"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_avatar_inactive">

            <TextView
                android:id="@+id/tvAvatarIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🤖"
                android:textSize="50sp" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/voice_ai_assistant"
            android:textColor="@color/voice_text_white"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Control Buttons -->
    <LinearLayout
        android:id="@+id/controlsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/callButtonContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Mute Button -->
        <LinearLayout
            android:id="@+id/btnMute"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:alpha="0.5"
            android:background="@drawable/bg_control_button_disabled"
            android:clickable="true"
            android:enabled="false"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvMuteIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="🎤"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/tvMuteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_btn_mute"
                android:textColor="@color/voice_text_disabled"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Speaker Button -->
        <LinearLayout
            android:id="@+id/btnSpeaker"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:alpha="0.5"
            android:background="@drawable/bg_control_button_disabled"
            android:clickable="true"
            android:enabled="false"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSpeakerIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="🔊"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/tvSpeakerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_btn_speaker_on"
                android:textColor="@color/voice_text_disabled"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Call/Hangup Button -->
    <LinearLayout
        android:id="@+id/callButtonContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="50dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/btnCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_call_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="200dp"
            android:orientation="horizontal"
            android:paddingHorizontal="50dp"
            android:paddingVertical="18dp">

            <TextView
                android:id="@+id/tvCallIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="📞"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/tvCallLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_btn_call"
                android:textColor="@color/voice_text_white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
